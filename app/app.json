{
  "expo": {
    "name": "React Native Template",
    "slug": "react-native-template",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "todoapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image-picker",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.raja.todoapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.raja.todoapp"
    }
  }
}
