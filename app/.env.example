# Only used for Realtime — all other operations go through FastAPI
EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321

# New-style publishable key (Supabase v2 projects). Preferred over legacy anon key.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Legacy JWT anon key — still accepted as a fallback
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
