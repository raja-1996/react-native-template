DEBUG=true

# Supabase — these values come from `supabase status` after running `supabase start`
SUPABASE_URL=http://localhost:54321

# New-style keys (Supabase v2 projects). Preferred over legacy JWT keys.
SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
SUPABASE_SECRET_DEFAULT_KEY=sb_secret_...

# Legacy JWT keys — still accepted as a fallback if new-style keys are not set
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=["http://localhost:8081","http://localhost:19006"]
